#!/bin/bash

# Example build configuration for src/main.sh and dist/bin/rpi5-archlinux-image.

BUILD_IMAGE_PATH="$BUILD_PROJECT_ROOT/dist/images/archlinuxarm-rpi5-aarch64.img"
BUILD_IMAGE_SIZE="4g"
BUILD_MOUNT_ROOT="/mnt/arch_build"
BUILD_MOUNT_BOOT="$BUILD_MOUNT_ROOT/boot"

BUILD_QEMU_IMAGE_PATH="$BUILD_PROJECT_ROOT/dist/images/archlinuxarm-qemu-aarch64.img"
BUILD_QEMU_BOOT_DIR="$BUILD_PROJECT_ROOT/dist/images/qemu-boot"
BUILD_QEMU_MOUNT_ROOT="/mnt/arch_qemu_build"
BUILD_QEMU_CPU="cortex-a72"
BUILD_QEMU_SMP="4"
BUILD_QEMU_MEMORY="2048"
BUILD_QEMU_SSH_HOST_PORT="2222"
BUILD_QEMU_KERNEL_CMDLINE="root=/dev/vda2 rw rootwait console=ttyAMA0"

BUILD_USER_NAME="dryam"
BUILD_USER_PASSWORD="dryam"
BUILD_SSH_USER="$BUILD_USER_NAME"
BUILD_ROOT_PASSWORD="root"
BUILD_TIMEZONE="Europe/Moscow"
BUILD_MKINITCPIO_HOOKS="HOOKS=(base systemd autodetect modconf kms keyboard keymap sd-vconsole block filesystems fsck)"

BUILD_MODULES=(
    "disk_image"
    "base_system"
    "boot_config"
    "services"
    "release_validation"
)

BUILD_PACKAGES=(
    "base"
    "archlinuxarm-keyring"
    "pacman-mirrorlist"
    "linux-rpi-16k"
    "raspberrypi-bootloader"
    "raspberrypi-utils"
    "firmware-raspberrypi"
    "wireless-regdb"
    "zram-generator"
    "sudo"
    "openssh"
)

BUILD_QEMU_MODULES=(
    "disk_image"
    "base_system"
    "qemu_boot_config"
    "services"
)

BUILD_QEMU_PACKAGES=(
    "base"
    "archlinuxarm-keyring"
    "pacman-mirrorlist"
    "linux-aarch64"
    "sudo"
    "openssh"
)
