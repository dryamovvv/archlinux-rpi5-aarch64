#!/usr/bin/ash
run_hook() {
    local bot_token="__BOT_TOKEN__"
    local chat_id="__CHAT_ID__"
    local luks_uuid="__LUKS_UUID__"
    local luks_name="cryptroot"
    local max_wait=120
    local start_time
    start_time=$(awk 'BEGIN{print systime()}' 2>/dev/null || echo 0)

    msg ":: Telegram unlock: polling Bot API (timeout ${max_wait}s)..."

    curl -s -m 5 "https://api.telegram.org/bot${bot_token}/sendMessage" \
        -d "chat_id=${chat_id}" \
        -d "text=Booted at $(date -u +%H:%M:%S). Send LUKS passphrase." \
        >/dev/null 2>&1 || msg ":: Telegram: sendMessage failed (API blocked?)"

    local offset=0
    local resp
    resp="$(curl -s -m 5 "https://api.telegram.org/bot${bot_token}/getUpdates" 2>/dev/null)"
    offset="$(echo "$resp" | sed -n 's/.*"update_id":\([0-9]*\).*/\1/p' | tail -1)"
    if [ -n "$offset" ]; then
        offset=$((offset + 1))
    fi

    while true; do
        local elapsed=0
        if [ "$start_time" != "0" ]; then
            elapsed=$(($(awk 'BEGIN{print systime()}' 2>/dev/null || echo 0) - start_time))
            [ "$elapsed" -ge "$max_wait" ] && { msg ":: Telegram: timeout, falling back to keyboard"; return 1; }
        fi

        resp="$(curl -s -m 15 "https://api.telegram.org/bot${bot_token}/getUpdates?offset=${offset}&timeout=10" 2>/dev/null)"

        if [ -n "$resp" ] && echo "$resp" | grep -q '"text":"'; then
            local text
            text="$(echo "$resp" | grep -o '"text":"[^"]*"' | head -1 | sed 's/"text":"//;s/"$//')"

            local new_offset
            new_offset="$(echo "$resp" | sed -n 's/.*"update_id":\([0-9]*\).*/\1/p' | tail -1)"
            [ -n "$new_offset" ] && offset=$((new_offset + 1))

            msg ":: Telegram: received passphrase, attempting unlock..."

            if printf '%s' "$text" | cryptsetup luksOpen "/dev/disk/by-uuid/${luks_uuid}" "${luks_name}" --key-file - 2>/dev/null; then
                msg ":: Telegram: LUKS unlocked"
                return 0
            else
                msg ":: Telegram: unlock failed, waiting for next message..."
            fi
        fi

        sleep 5
    done
}

# vim: set ft=sh ts=4 sw=4 et:
